#!/bin/sh -exu
package="$1"  ; shift
version="$1"  ; shift
root_url="$1" ; shift
brew update
brew tap runtimeverification/k "file://$(pwd)"

# Modify the formula to skip Spotless for PR testing
if [ -f "Formula/$package.rb" ]; then
  # Replace any spotless commands with skip flag
  sed -i "" -e 's/spotless:apply/spotless:check -Dspotless.check.skip=true/g' "Formula/$package.rb"
  sed -i "" -e 's/"spotless:apply"/"spotless:check", "-Dspotless.check.skip=true"/g' "Formula/$package.rb"
  sed -i "" -e 's/spotless:check/spotless:check -Dspotless.check.skip=true/g' "Formula/$package.rb"
  sed -i "" -e 's/"spotless:check"/"spotless:check", "-Dspotless.check.skip=true"/g' "Formula/$package.rb"
  echo "Modified formula to skip Spotless formatting"
  echo "Formula content after modification:"
  cat "Formula/$package.rb" | grep -i spotless || echo "No spotless commands found"
fi

MAVEN_OPTS="-Dspotless.check.skip=true" brew install $package --build-bottle -v
brew bottle --json $package --root-url="$root_url/v$version/"
cat *.bottle.json
brew bottle --merge --write --no-commit *.bottle.json
cp $(brew formula $package) Formula/$package.rb
